# StyleMart — .gitignore

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
dist/
out/
build/

# Turbo cache
.turbo/

# Testing
coverage/
*.lcov

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# AI/Model specific
.claude/
.planning/
.brain/
.gemini/
*.md.tmp

# TypeScript
*.tsbuildinfo
next-env.d.ts
