# ============================================================
# StyleMart E-Commerce Platform — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# All variables are consumed via process.env — defined once at
# the monorepo root and available to all workspaces.
# ============================================================

# ── DATABASE (MongoDB Atlas) ────────────────────────────────
# MongoDB connection string — used by Mongoose ODM at runtime
MONGODB_URI="mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority"

# ── REDIS (Upstash) ──────────────────────────────────────────
# Upstash Redis REST URL — used by @upstash/redis and @upstash/ratelimit
UPSTASH_REDIS_REST_URL="https://[your-redis].upstash.io"
UPSTASH_REDIS_REST_TOKEN="AX...your-token-here..."

# IORedis-compatible URL — used by BullMQ job queues
REDIS_URL="rediss://:[password]@[host].upstash.io:6380"

# ── CLOUDINARY ───────────────────────────────────────────────
# Media storage for product images and user avatars
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your_api_secret_here"

# ── RAZORPAY ─────────────────────────────────────────────────
# Use rzp_test_* keys for development, rzp_live_* for production
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
# Webhook secret set in Razorpay dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret_here"

# ── AUTHENTICATION (NextAuth.js v5 / Auth.js) ────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-minimum-32-characters-long"
# The full public URL of the app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID="xxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxx"

# ── EMAIL / SMTP ─────────────────────────────────────────────
# Use Gmail App Password (not your main password) or SendGrid SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"   # true for port 465
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="xxxx xxxx xxxx xxxx"     # Gmail App Password
SMTP_FROM="StyleMart <noreply@stylemart.in>"

# ── APPLICATION ──────────────────────────────────────────────
APP_URL="http://localhost:3000"
NODE_ENV="development"

# JWT secret for custom token signing (separate from NextAuth)
JWT_SECRET="your-jwt-secret-minimum-32-characters"

# Invite token required to register as SUPER_ADMIN during seeding
# Change this to a long random string before first deploy
ADMIN_INVITE_TOKEN="super-secret-invite-token-change-before-deploy"

# ── OPTIONAL: MONITORING & ANALYTICS ────────────────────────
# SENTRY_DSN=""
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
# VERCEL_ANALYTICS_ID=""
