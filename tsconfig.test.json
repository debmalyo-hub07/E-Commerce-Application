{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["frontend/src/*"],
      "@stylemart/types": ["shared/types/index.ts"],
      "@stylemart/shared/constants": ["shared/constants/index.ts"],
      "@stylemart/shared/utils": ["shared/utils/index.ts"],
      "@stylemart/shared/lib/*": ["shared/lib/*"]
    }
  },
  "include": ["__tests__/**/*", "jest.config.js"]
}
